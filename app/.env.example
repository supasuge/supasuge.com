# ============================================================================
# .env.example (SAFE TO COMMIT)
# Copy to .env and fill values:
#   cp .env.example .env
#   ./scripts/setup_env.sh   (interactive)
#   ./scripts/gensecrets.sh  (fills secrets into .env)
# ============================================================================

# ---- Site identity ----
DOMAIN=supasuge.com
SITE_NAME=Evan Pardon's Portfolio
SITE_URL=https://supasuge.com

# Optional metadata (doesn't affect core app logic unless you use it somewhere)
ADMIN_EMAIL=admin@supasuge.com
ROOT_URL=https://supasuge.com/

# ---- Flask runtime ----
HOST=0.0.0.0
PORT=8000
FLASK_APP=app.py
ADMIN_ENABLED=0

# ---- Local Development Mode ----
# Set to 1 for local development (uses SQLite, debug mode, no SSL, relaxed security)
# Set to 0 or omit for production (uses MySQL, production settings)
LOCAL_DEV=0

# ---- Secrets (REQUIRED; generated by scripts) ----
# SECRET_KEY must be long and random (>= 48 chars recommended)
SECRET_KEY=
# ANALYTICS_SALT must be long and random (>= 32 chars recommended)
ANALYTICS_SALT=

# ---- Database (REQUIRED for production, optional for LOCAL_DEV=1) ----
# Production (MySQL - recommended):
DATABASE_URL=mysql+pymysql://blogapp:<MYSQL_PASSWORD>@db:3306/blog?charset=utf8mb4
# Host running app.py (MySQL on localhost):
# DATABASE_URL=mysql+pymysql://blogapp:<MYSQL_PASSWORD>@127.0.0.1:3306/blog?charset=utf8mb4
# Local development with LOCAL_DEV=1:
# DATABASE_URL is optional - will automatically use SQLite at instance/blog.db
# Explicit SQLite (if needed):
# DATABASE_URL=sqlite:///instance/blog.db

# ---- MySQL container credentials (REQUIRED for docker compose db) ----
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---- Content ----
CONTENT_DIR=content/articles

# ---- Rate limiting storage ----
# Local dev:
# RATELIMIT_STORAGE_URL=memory://
# Docker/prod:
RATELIMIT_STORAGE_URL=redis://redis:6379/0
RATELIMIT_DEFAULT=300/hour

# ---- Reverse proxy / security ----
BEHIND_PROXY=1
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1

ALLOWED_HOSTS=supasuge.com,www.supasuge.com
COOKIE_SECURE=1
COOKIE_SAMESITE=Lax
ENABLE_HSTS=1

# Optional: override CSP (your app already has a default)
# CSP=default-src 'self'; img-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; base-uri 'self'; frame-ancestors 'none'

# ---- Admin SSH auth ----
ADMIN_SSH_PUBLIC_KEY_PATH=keys/admin_ssh.pub
ADMIN_SSH_PRINCIPAL=admin
ADMIN_SSH_NAMESPACE=supasuge-admin
ADMIN_SESSION_TIMEOUT=28800
ADMIN_SESSION_RENEWAL=3600
ADMIN_CHALLENGE_EXPIRY=300

# ---- Analytics ----
ANALYTICS_ENABLED=1
ANALYTICS_RETENTION_DAYS=15
ANALYTICS_RESPECT_DNT=1
ANALYTICS_SESSION_TIMEOUT=1800
GEOIP_DB_PATH=data/GeoLite2-City.mmdb

# ---- Upload policy ----
MAX_UPLOAD_SIZE=2097152

# ---- Certbot (REQUIRED for auto TLS) ----
CERTBOT_EMAIL=epardo1742@proton.me

# ---- Optional celery (only if you actually run it) ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Gunicorn tuning (optional) ----
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
LOG_LEVEL=info

# ---- DB pool tuning (optional) ----
DB_POOL_RECYCLE=1800
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Alembic config path (only used if you reference it)
ALEMBIC_CONFIG=/app/alembic.ini
