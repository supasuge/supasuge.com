set -euo pipefail

# -------------------------------------------------------------------
# sitectl.sh - deploy/test/maintain supasuge.com
#
# Repo assumptions (based on your current tree):
#   - Repo root contains:
#       alembic.ini, migrations/, nginx/, docker-compose.yml, instance/
#       scripts/sync.py, scripts/build_sitemap.py
#   - Primary SQLite dev DB path: instance/site.db
#   - "Junk" to remove: ./site.db, old deploy scripts, __pycache__, etc.
#
# Commands:
#   ./scripts/sitectl.sh doctor          # sanity check repo + env
#   ./scripts/sitectl.sh cleanup         # remove junk + old DBs/scripts
#   ./scripts/sitectl.sh dev             # local gunicorn (sqlite, no docker)
#   ./scripts/sitectl.sh compose-up      # docker stack up (db/redis/web/nginx)
#   ./scripts/sitectl.sh compose-down    # docker compose down
#   ./scripts/sitectl.sh migrate         # alembic upgrade head (in web)
#   ./scripts/sitectl.sh sync            # one-shot content sync (in web)
#   ./scripts/sitectl.sh sitemap         # build sitemap.xml (in web)
#   ./scripts/sitectl.sh logs [svc]      # follow logs
#   ./scripts/sitectl.sh nginx-gen       # generate nginx/conf.d/site.conf from template
#   ./scripts/sitectl.sh init-cert       # initial Let's Encrypt cert (webroot)
#   ./scripts/sitectl.sh renew-cert      # renew cert + reload nginx
# -------------------------------------------------------------------

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${ROOT_DIR}/.env"

cd "$ROOT_DIR"

log()  { printf "\033[0;34m[sitectl]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[warn]\033[0m %s\n" "$*"; }
err()  { printf "\033[0;31m[err]\033[0m %s\n" "$*"; }

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { err "Missing command: $1"; exit 1; }
}

compose() {
  if docker compose version >/dev/null 2>&1; then
    docker compose "$@"
  else
    need_cmd docker-compose
    docker-compose "$@"
  fi
}

load_env_optional() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

load_env_required() {
  if [[ ! -f "$ENV_FILE" ]]; then
    err "Missing .env at $ENV_FILE"
    err "Create it first (DOMAIN, CERTBOT_EMAIL, SECRET_KEY, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD)."
    exit 1
  fi

  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a

  : "${DOMAIN:?DOMAIN not set in .env}"
  : "${CERTBOT_EMAIL:?CERTBOT_EMAIL not set in .env}"
  : "${SECRET_KEY:?SECRET_KEY not set in .env}"
  : "${MYSQL_PASSWORD:?MYSQL_PASSWORD not set in .env}"
  : "${MYSQL_ROOT_PASSWORD:?MYSQL_ROOT_PASSWORD not set in .env}"
}

setup_dirs() {
  mkdir -p nginx/webroot/.well-known/acme-challenge
  mkdir -p instance keys data content/articles public static templates migrations
  chmod 755 nginx/webroot || true
}

# --- Doctor / cleanup ---------------------------------------------------------

cmd_doctor() {
  log "Running repo sanity checks..."

  local problems=0

  [[ -f alembic.ini ]] || { err "Missing alembic.ini"; problems=1; }
  [[ -d migrations ]] || { err "Missing migrations/"; problems=1; }
  [[ -d nginx ]] || { err "Missing nginx/"; problems=1; }
  [[ -f docker-compose.yml ]] || { err "Missing docker-compose.yml"; problems=1; }
  [[ -f scripts/sync.py ]] || { err "Missing scripts/sync.py"; problems=1; }
  [[ -f nginx/templates/site.conf.template ]] || { err "Missing nginx/templates/site.conf.template"; problems=1; }

  # Warn about known junk
  [[ -f site.db ]] && warn "Found stray ./site.db (junk). Use: ./scripts/sitectl.sh cleanup"
  [[ -f deploy.sh ]] && warn "Found ./deploy.sh (junk). Use: ./scripts/sitectl.sh cleanup"
  [[ -f scripts/deploy.sh ]] && warn "Found ./scripts/deploy.sh (junk). Use: ./scripts/sitectl.sh cleanup"

  if [[ $problems -ne 0 ]]; then
    err "Doctor failed. Fix the above before deploying."
    exit 1
  fi

  log "Doctor OK."
}

cmd_cleanup() {
  log "Removing junk files and stale artifacts..."

  # kill classic junk
  rm -f ./site.db ./site.db-journal ./site.db-wal ./site.db-shm || true
  rm -f ./deploy.sh ./scripts/deploy.sh || true

  # python caches
  find . -type d -name "__pycache__" -prune -exec rm -rf {} + 2>/dev/null || true
  find . -type f -name "*.pyc" -delete 2>/dev/null || true
  find . -type f -name "*.pyo" -delete 2>/dev/null || true
  find . -type f -name ".DS_Store" -delete 2>/dev/null || true

  # stray build outputs
  rm -rf .pytest_cache .mypy_cache .ruff_cache dist build 2>/dev/null || true

  # optional: docker cleanup (safe-ish)
  if command -v docker >/dev/null 2>&1; then
    warn "Pruning dangling docker images/volumes (dangling only)..."
    docker image prune -f >/dev/null 2>&1 || true
    docker volume prune -f >/dev/null 2>&1 || true
  fi

  log "Cleanup done."
}

# --- Nginx config generation --------------------------------------------------

cmd_nginx_gen() {
  load_env_required
  setup_dirs

  local tmpl="nginx/templates/site.conf.template"
  local out="nginx/conf.d/site.conf"

  if [[ ! -f "$tmpl" ]]; then
    err "Missing template: $tmpl"
    exit 1
  fi

  need_cmd envsubst

  log "Generating nginx conf from template -> ${out}"
  DOMAIN="$DOMAIN" envsubst '${DOMAIN}' < "$tmpl" > "$out"

  log "Generated: $out"
}

# --- Local dev ---------------------------------------------------------------

cmd_dev() {
  log "Local dev gunicorn test (no docker)."

  # Use .env if present, but don’t require MySQL secrets for local sqlite testing
  load_env_optional

  export DATABASE_URL="${DATABASE_URL:-sqlite:///instance/site.db}"
  export RATELIMIT_STORAGE_URL="${RATELIMIT_STORAGE_URL:-memory://}"
  export AUTO_SYNC_ON_START=0

  if [[ -z "${SECRET_KEY:-}" ]]; then
