        read -p "Do you want to overwrite it? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Setup cancelled."
            exit 0
        fi
    fi

    # Start with .env.example as template
    cp "$ENV_EXAMPLE" "$ENV_FILE"
