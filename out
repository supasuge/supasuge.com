#!/usr/bin/env python3
"""
Enhanced post creation script for supasuge.com

Features:
- Interactive category selection from existing categories
- Create new categories on-the-fly
- Create markdown posts with proper frontmatter
- Optional database registration
- Optionally open the file in an editor
"""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
import textwrap
from datetime import date
from pathlib import Path
from typing import Optional

# Add parent directory to path to import project modules
sys.path.insert(0, str(Path(__file__).parent.parent))

from security import slugify

TEMPLATE = """---
title: "{title}"
summary: "{summary}"
tags: [{tags}]
published: {published}
date: {date}
---

# {title}

{summary}

## Content

Write your content here.
"""


def get_existing_categories(content_dir: Path) -> list[str]:
    """Get all existing category directories from content/articles."""
    if not content_dir.exists():
        return []

    categories = []
    for item in content_dir.iterdir():
        if item.is_dir() and not item.name.startswith("."):
            categories.append(item.name)

    return sorted(categories)


def prompt_choice(prompt: str, choices: list[str], allow_new: bool = False) -> str:
    """Prompt user to select from choices or enter a new value."""
    print(f"\n{prompt}")
    print("-" * 50)

    for i, choice in enumerate(choices, 1):
        print(f"  {i}. {choice}")

    if allow_new:
        print(f"  {len(choices) + 1}. [Create new]")

    print("-" * 50)

    while True:
        try:
            selection = input("Select number: ").strip()
            idx = int(selection) - 1

            if 0 <= idx < len(choices):
                return choices[idx]
            elif allow_new and idx == len(choices):
                new_value = input("Enter new category name: ").strip()
                if new_value:
                    return new_value
                print("Category name cannot be empty!")
            else:
                print(f"Please enter a number between 1 and {len(choices) + (1 if allow_new else 0)}")
        except (ValueError, KeyboardInterrupt):
            print("\nOperation cancelled.")
            sys.exit(1)


def prompt_yes_no(prompt: str, default: bool = True) -> bool:
    """Prompt user for yes/no input."""
    default_str = "Y/n" if default else "y/N"
    while True:
        response = input(f"{prompt} [{default_str}]: ").strip().lower()
        if not response:
            return default
        if response in ('y', 'yes'):
            return True
        if response in ('n', 'no'):
            return False
        print("Please enter 'y' or 'n'")


def register_in_database(content_dir: Path, verbose: bool = True) -> dict:
    """
    Register the new post in the database by running the sync process.

    Returns:
        Dict with sync results from content_sync
    """
    try:
        # Import here to avoid requiring database for file-only operations
        from content_sync import sync_content
        from models import db
        from sqlalchemy import create_engine
        from sqlalchemy.orm import sessionmaker

        # Determine database path
        db_path = "/home/supasuge/Documents/supasuge.com/instance/site.db"
        if not db_path.exists():
            if verbose:
                print(f"\n⚠️  Database not found at {db_path}")
                print("Post file created, but not registered in database.")
            return {}

        # Create database session
        engine = create_engine(f"sqlite:///{db_path}")
        Session = sessionmaker(bind=engine)
        session = Session()

        # Sync content
        results = sync_content(str(content_dir), session)
        session.close()

        if verbose:
            print("\n✓ Database sync completed:")
            print(f"  Created: {results.get('created', 0)}")
            print(f"  Updated: {results.get('updated', 0)}")
            print(f"  Total indexed: {results.get('total_indexed', 0)}")

        return results

    except ImportError as e:
        if verbose:
            print(f"\n⚠️  Could not import required modules: {e}")
            print("Post file created, but not registered in database.")
        return {}
    except Exception as e:
        if verbose:
            print(f"\n⚠️  Error during database sync: {e}")
            print("Post file created, but not registered in database.")
        return {}


def create_post(
    category: str,
    title: str,
    summary: str = "",
    tags: list[str] = None,
    published: bool = True,
    subdir: str = "",
    content_dir: Optional[Path] = None,
    interactive: bool = False,
    sync_db: bool = False,
    open_editor: bool = False,
) -> Path:
    """
    Create a new markdown post.

    Args:
        category: Category slug (e.g., 'ctf', 'pentesting')
        title: Post title
        summary: Post summary/description
        tags: List of tags
        published: Whether post should be published
        subdir: Optional subdirectory under category
        content_dir: Content directory path (default: content/articles)
        interactive: Whether to prompt for missing values
        sync_db: Whether to register in database after creation
        open_editor: Whether to open the file in $EDITOR after creation

    Returns:
        Path to the created markdown file
    """
    if content_dir is None:
        content_dir = Path(__file__).parent.parent / "content" / "articles"

    if tags is None:
        tags = []

    # Interactive category selection
    if interactive and not category:
        existing = get_existing_categories(content_dir)
        if existing:
            category = prompt_choice(
                "Select a category:",
                existing,
                allow_new=True
            )
        else:
            category = input("Enter category name: ").strip()

    if not category:
        raise ValueError("Category is required")

    # Interactive title input
    if interactive and not title:
        title = input("Enter post title: ").strip()
        if not title:
            raise ValueError("Title is required")

    # Interactive summary
    if interactive and not summary:
        summary = input("Enter post summary (optional): ").strip()

    # Interactive tags
    if interactive and not tags:
        tags_input = input("Enter tags (comma-separated, optional): ").strip()
        if tags_input:
            tags = [t.strip() for t in tags_input.split(",") if t.strip()]

    # Slugify everything
    category_slug = slugify(category)
    title_slug = slugify(title)
    tag_slugs = [slugify(t) for t in tags]

    # Format tags for YAML
    tags_str = ", ".join(f'"{t}"' for t in tag_slugs)

    # Determine target directory
    if category_slug == "general":
        target_dir = content_dir / (subdir.strip("/") if subdir else "")
    else:
        target_dir = content_dir / category_slug / (subdir.strip("/") if subdir else "")

    target_dir.mkdir(parents=True, exist_ok=True)
    file_path = target_dir / f"{title_slug}.md"

    # Check if file exists
    if file_path.exists():
        raise FileExistsError(f"File already exists: {file_path}")

    # Create the file
    content = textwrap.dedent(TEMPLATE.format(
        title=title,
        summary=summary,
        tags=tags_str,
        published=str(published).lower(),
        date=date.today().isoformat(),
    ))

    file_path.write_text(content, encoding="utf-8")
    print(f"\n✓ Created: {file_path}")

    # Optional database sync
    if sync_db or (interactive and prompt_yes_no("\nRegister post in database?", default=True)):
        register_in_database(content_dir, verbose=True)

    # Optional editor open
    if open_editor or (interactive and prompt_yes_no("\nOpen in editor?", default=True)):
        editor = os.environ.get("EDITOR", "nano")
        try:
            subprocess.run([editor, str(file_path)])
        except Exception as e:
            print(f"⚠️  Could not open editor: {e}")

    return file_path


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Create a new markdown post with optional database registration",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
        Examples:
          # Interactive mode (recommended for new posts)
          %(prog)s -i

          # Quick post with all options
          %(prog)s ctf "My CTF Writeup" -s "Solved an interesting challenge" -t ctf,web,sqli

          # Create post in subdirectory
          %(prog)s pentesting "Network Scan" --subdir techniques

          # Create draft (unpublished)
          %(prog)s guides "WIP Article" --draft

          # Create and sync to database
          %(prog)s linux "Bash Tips" --sync

          # List existing categories
          %(prog)s --list-categories
        """)
    )

    parser.add_argument(
        "category",
        nargs="?",
        help="Category name (or select interactively with -i)"
    )
    parser.add_argument(
        "title",
        nargs="?",
        help="Post title (or enter interactively with -i)"
    )
    parser.add_argument(
        "-s", "--summary",
        default="",
        help="Post summary/description"
    )
    parser.add_argument(
        "-t", "--tags",
        default="",
        help="Comma-separated tags"
    )
    parser.add_argument(
        "--subdir",
        default="",
        help="Subdirectory under category"
    )
    parser.add_argument(
        "--draft",
        action="store_true",
        help="Mark as unpublished (draft)"
    )
    parser.add_argument(
        "-i", "--interactive",
        action="store_true",
        help="Interactive mode with prompts"
    )
    parser.add_argument(
        "--sync",
        action="store_true",
        help="Register in database after creation"
    )
    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Don't open in editor after creation"
    )
    parser.add_argument(
        "--list-categories",
        action="store_true",
        help="List existing categories and exit"
    )

    args = parser.parse_args()

    content_dir = Path(__file__).parent.parent / "content" / "articles"

    # List categories mode
    if args.list_categories:
        categories = get_existing_categories(content_dir)
        if categories:
            print("\nExisting categories:")
            for cat in categories:
                count = len(list((content_dir / cat).glob("**/*.md")))
                print(f"  • {cat} ({count} posts)")
        else:
            print("\nNo categories found.")
        return

    # Parse tags
    tags = [t.strip() for t in args.tags.split(",") if t.strip()] if args.tags else []

    # Validate required args in non-interactive mode
    if not args.interactive:
        if not args.category or not args.title:
            parser.error("category and title are required (or use -i for interactive mode)")

    try:
        create_post(
            category=args.category or "",
            title=args.title or "",
            summary=args.summary,
            tags=tags,
            published=not args.draft,
            subdir=args.subdir,
            content_dir=content_dir,
            interactive=args.interactive,
            sync_db=args.sync,
            open_editor=not args.no_open and (args.interactive or args.sync),
        )
    except (ValueError, FileExistsError) as e:
        print(f"\n✗ Error: {e}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n\nOperation cancelled.")
        sys.exit(1)


if __name__ == "__main__":
    main()
