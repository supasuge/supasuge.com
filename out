    chmod 700 "$SCRIPT_DIR/instance" 2>/dev/null || true
    chmod 700 "$SCRIPT_DIR/keys" 2>/dev/null || true

    log_success "Directories created and configured"
}

# --- Nginx Configuration -----------------------------------------------------
generate_nginx_config() {
    log_step "Generating nginx configuration..."

    local template="$SCRIPT_DIR/nginx/templates/site.conf.template"
    local output="$SCRIPT_DIR/nginx/conf.d/site.conf"

    if [[ ! -f "$template" ]]; then
        log_error "Nginx template not found: $template"
        exit 1
    fi

    # Generate config from template
    DOMAIN="${DOMAIN}" envsubst '${DOMAIN}' < "$template" > "$output"

    log_success "Generated nginx config: nginx/conf.d/site.conf"
}

# --- SSL Certificate Management ---------------------------------------------
check_ssl_exists() {
    # Check if certificates exist in Docker volume
    if docker_compose run --rm --entrypoint="" certbot test -f "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem" 2>/dev/null; then
        return 0
    fi
    return 1
}

obtain_ssl_certificates() {
    log_step "Obtaining SSL certificates from Let's Encrypt..."

    # Ensure nginx is running for ACME challenge
    log_info "Ensuring nginx is running for ACME HTTP-01 challenge..."
    docker_compose up -d nginx
    sleep 5

    # Request certificate
    log_info "Requesting certificate for ${DOMAIN} and www.${DOMAIN}..."

    if docker_compose run --rm certbot certonly \
        --webroot \
        --webroot-path=/var/www/certbot \
        --email "$CERTBOT_EMAIL" \
