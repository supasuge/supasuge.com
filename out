  fi

  log "Using DATABASE_URL=${DATABASE_URL}"
  setup_dirs

  # Ensure sqlite directory exists and is writable
  if [[ "$DATABASE_URL" == sqlite:///instance/* ]]; then
    mkdir -p instance
    chmod 700 instance || true
    touch instance/site.db 2>/dev/null || true
  fi

  log "Running migrations (local)..."
  alembic upgrade head

  log "Running one-shot content sync (local)..."
  python scripts/sync.py

  log "Starting gunicorn (2 workers, threads 4)..."
  exec gunicorn --config gunicorn.conf.py "app:create_app()"
}

# --- Docker stack ------------------------------------------------------------

cmd_compose_up() {
  need_cmd docker
  load_env_required
  setup_dirs

  # Generate nginx conf from template (hard requirement for LE paths)
  cmd_nginx_gen

  log "Building images..."
  compose build

  log "Starting db + redis..."
  compose up -d db redis

  log "Starting web..."
  compose up -d web

  log "Running migrations (web container)..."
  cmd_migrate

  log "Running one-shot content sync (web container)..."
  cmd_sync

  log "Building sitemap.xml (web container)..."
  cmd_sitemap

  log "Starting nginx..."
  compose up -d nginx

  log "Stack is up. Visit: https://${DOMAIN}"
  compose ps
}

cmd_compose_down() {
  log "Stopping stack..."
  compose down
}

cmd_logs() {
  local svc="${1:-}"
  if [[ -n "$svc" ]]; then
    compose logs -f "$svc"
  else
    compose logs -f
  fi
}

cmd_migrate() {
  load_env_optional || true
  log "Running Alembic migrations inside web container..."
  compose exec -T web alembic upgrade head
}

cmd_sync() {
  load_env_optional || true
  log "Running one-shot content sync inside web container..."
  compose exec -T web python scripts/sync.py
}

cmd_sitemap() {
  load_env_optional || true
  log "Building sitemap.xml inside web container..."
  compose exec -T web python scripts/build_sitemap.py
}

# --- Certbot -----------------------------------------------------------------

cmd_init_cert() {
  load_env_required
  setup_dirs
  cmd_nginx_gen

  log "Starting nginx (HTTP reachable) for ACME webroot..."
  compose up -d nginx

  log "Requesting cert via webroot for ${DOMAIN} + www.${DOMAIN}..."
  compose run --rm certbot certonly \
    --webroot --webroot-path /var/www/certbot \
    -d "${DOMAIN}" -d "www.${DOMAIN}" \
    --email "${CERTBOT_EMAIL}" --agree-tos --no-eff-email

  log "Reloading nginx to pick up new cert..."
  compose exec -T nginx nginx -s reload
}

cmd_renew_cert() {
  load_env_required
  log "Renewing certs..."
  compose run --rm certbot renew

  log "Reloading nginx (required to use renewed certs)..."
  compose exec -T nginx nginx -s reload
}

# --- Usage -------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: $0 <command>

Core:
  doctor                Sanity check repo structure
  cleanup               Remove junk (stray DBs, bad deploy scripts, caches)

Local:
  dev                   Local gunicorn test (sqlite, no docker)

Docker:
  compose-up            Bring up stack (db/redis/web/nginx), migrate/sync/sitemap
  compose-down          Stop stack
  logs [service]        Follow logs
  migrate               Run alembic upgrade head in web container
  sync                  Run one-shot content sync in web container
  sitemap               Build sitemap.xml in web container

Nginx/Certbot:
  nginx-gen             Generate nginx/conf.d/site.conf from template
  init-cert             Obtain initial LetsEncrypt cert via webroot
  renew-cert            Renew certs + reload nginx
EOF
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    doctor) cmd_doctor ;;
    cleanup) cmd_cleanup ;;
    dev) cmd_dev ;;

    compose-up) cmd_compose_up ;;
    compose-down) cmd_compose_down ;;
    logs) cmd_logs "${1:-}" ;;
    migrate) cmd_migrate ;;
    sync) cmd_sync ;;
    sitemap) cmd_sitemap ;;

    nginx-gen) cmd_nginx_gen ;;
    init-cert) cmd_init_cert ;;
    renew-cert) cmd_renew_cert ;;

    ""|-h|--help) usage ;;
    *) err "Unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"

