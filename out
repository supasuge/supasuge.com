# --- Health Checks -----------------------------------------------------------
verify_deployment() {
    log_step "Verifying deployment health..."

    local all_healthy=true

    # Check each service
    local services=("db" "redis" "web" "nginx")
    for service in "${services[@]}"; do
        if check_service_health "$service"; then
            log_success "✓ $service is healthy"
        else
            log_error "✗ $service is not healthy"
            all_healthy=false
        fi
    done

    # Check web application health endpoint
    log_info "Checking web application health endpoint..."
    if docker_compose exec -T web python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=5).read()" &>/dev/null; then
        log_success "✓ Web application health check passed"
    else
        log_error "✗ Web application health check failed"
        all_healthy=false
    fi

    # Check nginx accessibility
    log_info "Checking nginx accessibility..."
    if docker_compose exec -T nginx nginx -t &>/dev/null; then
        log_success "✓ Nginx configuration is valid"
    else
        log_error "✗ Nginx configuration has errors"
        all_healthy=false
    fi

    if [[ "$all_healthy" == "true" ]]; then
        log_success "All health checks passed!"
        return 0
    else
        log_error "Some health checks failed"
        return 1
    fi
}

# --- Deployment Functions ----------------------------------------------------
deploy_initial() {
    log_info "========================================="
    log_info "Starting INITIAL deployment..."
    log_info "========================================="
    log_info ""

    preflight_checks
    setup_directories
    generate_nginx_config

    # Build Docker images
    log_step "Building Docker images..."
    log_info "This may take several minutes on first run..."
    if docker_compose build --no-cache; then
        log_success "Docker images built successfully"
    else
        log_error "Docker image build failed!"
        exit 1
    fi

    # Start database first
    log_step "Starting MySQL database..."
    docker_compose up -d db

    # Wait for database to be healthy
    if ! wait_for_service db 60; then
        log_error "Database failed to start"
        log_info "Check logs with: docker compose logs db"
        exit 1
    fi

    # Start Redis
    log_step "Starting Redis..."
    docker_compose up -d redis

    if ! wait_for_service redis 30; then
        log_error "Redis failed to start"
        exit 1
    fi

    # Start web application
    log_step "Starting web application..."
    docker_compose up -d web

    if ! wait_for_service web 60; then
        log_error "Web application failed to start"
        log_info "Check logs with: docker compose logs web"
        exit 1
    fi

    # Run migrations
    sleep 5  # Give app a moment to fully initialize
    if ! run_migrations; then
        log_error "Migration failed! Stopping deployment."
        exit 1
    fi

    # Sync content
    sync_content
    build_sitemap

    # Start nginx
    log_step "Starting nginx..."
    docker_compose up -d nginx

    if ! wait_for_service nginx 30; then
        log_error "Nginx failed to start"
        exit 1
    fi

    # Verify deployment
    sleep 3
    if ! verify_deployment; then
        log_warn "Deployment verification had issues, but continuing..."
    fi

    # Obtain SSL certificates
    if check_ssl_exists; then
        log_info "SSL certificates already exist, reloading nginx..."
        docker_compose exec nginx nginx -s reload || true
    else
        log_info ""
        log_info "No SSL certificates found. Attempting to obtain them now..."
        obtain_ssl_certificates || log_warn "Continuing without SSL (obtain later)"
    fi

    # Final verification
    log_info ""
    log_step "Final deployment status:"
    docker_compose ps

    log_info ""
    log_success "========================================="
    log_success "DEPLOYMENT COMPLETE!"
    log_success "========================================="
    log_info ""
    log_info "Your site should be accessible at:"
    if check_ssl_exists; then
        log_info "  → https://${DOMAIN}"
        log_info "  → https://www.${DOMAIN}"
    else
        log_warn "  → http://${DOMAIN} (HTTP only - SSL not configured)"
        log_info ""
        log_info "To obtain SSL certificates, run:"
        log_info "  ./scripts/sitectl.sh init-cert"
    fi
    log_info ""
    log_info "Useful commands:"
    log_info "  View logs:        docker compose logs -f [service]"
    log_info "  Stop services:    docker compose down"
    log_info "  Restart service:  docker compose restart [service]"
    log_info "  Backup database:  ./deploy.sh backup"
    log_info "  Renew SSL:        ./scripts/sitectl.sh renew-cert"
    log_info ""
}

deploy_update() {
    log_info "========================================="
    log_info "Starting UPDATE deployment..."
    log_info "========================================="
    log_info ""

    preflight_checks

    # Check if services are running
    if ! docker_compose ps | grep -q "Up"; then
        log_error "No services are currently running!"
        log_info "For first deployment, use: ./deploy.sh deploy"
        exit 1
    fi

    # Backup database before update
    backup_database

    # Regenerate nginx config in case of changes
    generate_nginx_config

    # Rebuild images
    log_step "Rebuilding Docker images..."
    if docker_compose build; then
        log_success "Docker images rebuilt"
    else
        log_error "Docker image rebuild failed!"
        exit 1
    fi

    # Gracefully restart services
    log_step "Restarting services..."

    # Restart web first (will trigger new migrations)
    docker_compose up -d --no-deps web

    if ! wait_for_service web 60; then
        log_error "Web service failed to restart!"
        log_warn "Rolling back to previous version..."
        docker_compose restart web
        exit 1
    fi

    # Run any new migrations
    sleep 5
    if ! run_migrations; then
        log_error "Migrations failed during update!"
        exit 1
    fi

    # Sync content and rebuild sitemap
    sync_content
    build_sitemap

    # Restart nginx to pick up any config changes
    docker_compose restart nginx

    # Verify everything is healthy
    sleep 3
    if ! verify_deployment; then
        log_warn "Some health checks failed after update"
        log_info "Check logs with: docker compose logs"
    fi

    log_info ""
    log_success "========================================="
    log_success "UPDATE COMPLETE!"
    log_success "========================================="
    log_info ""
    docker_compose ps
}

# --- Management Commands -----------------------------------------------------
cmd_logs() {
    local service="${1:-}"
    if [[ -n "$service" ]]; then
        docker_compose logs -f "$service"
    else
        docker_compose logs -f
    fi
}

cmd_status() {
    log_info "Service Status:"
    docker_compose ps
    echo ""
    log_info "Resource Usage:"
    docker stats --no-stream $(docker_compose ps -q) 2>/dev/null || true
}

cmd_backup() {
    source "$ENV_FILE"
    backup_database
}

cmd_shell() {
    local service="${1:-web}"
    docker_compose exec "$service" /bin/bash
}

cmd_restart() {
    local service="${1:-}"
    if [[ -n "$service" ]]; then
        log_info "Restarting service: $service"
        docker_compose restart "$service"
    else
        log_info "Restarting all services"
        docker_compose restart
    fi
    log_success "Restart complete"
}

# --- Usage -------------------------------------------------------------------
usage() {
    cat <<EOF
${BLUE}supasuge.com Deployment Script${NC}

${CYAN}Usage:${NC} $0 <command> [options]

${CYAN}Deployment Commands:${NC}
  ${GREEN}deploy${NC}              Initial production deployment (first time)
  ${GREEN}update${NC}              Update existing deployment

${CYAN}Management Commands:${NC}
  ${GREEN}status${NC}              Show deployment status and resource usage
  ${GREEN}logs${NC} [service]      Follow logs (all services or specific one)
  ${GREEN}backup${NC}              Create database backup
  ${GREEN}shell${NC} [service]     Open shell in container (default: web)
  ${GREEN}restart${NC} [service]   Restart services (all or specific one)

${CYAN}Examples:${NC}
  $0 deploy                # First-time deployment
  $0 update                # Deploy updates
  $0 logs web              # View web application logs
  $0 status                # Check all services
  $0 backup                # Backup database
  $0 shell web             # Shell into web container
  $0 restart nginx         # Restart nginx

${CYAN}For SSL certificate management:${NC}
  ./scripts/sitectl.sh init-cert    # Obtain SSL certificates
  ./scripts/sitectl.sh renew-cert   # Renew SSL certificates

EOF
}

# --- Main --------------------------------------------------------------------
main() {
    cd "$SCRIPT_DIR"

    # Initialize deployment log
    echo "=== Deployment started at $(date) ===" >> "$DEPLOYMENT_LOG"

    case "${1:-}" in
        deploy)
            deploy_initial
            ;;
        update)
            deploy_update
            ;;
        logs)
            cmd_logs "${2:-}"
            ;;
        status)
            cmd_status
            ;;
        backup)
            cmd_backup
            ;;
        shell)
            cmd_shell "${2:-}"
            ;;
        restart)
            cmd_restart "${2:-}"
            ;;
        -h|--help|help)
            usage
            ;;
        "")
            log_error "No command specified"
            echo ""
            usage
            exit 1
            ;;
        *)
            log_error "Unknown command: $1"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
