        <div class="tag-input-wrapper">
          <input type="text"
                 class="tag-input"
                 placeholder="Add tags..."
                 autocomplete="off">
          <div class="tag-dropdown" style="display:none;"></div>
        </div>
        <input type="hidden" name="tag_slugs" value="${this.selectedTags.join(',')}">
      </div>
    `;
  }

  attachEvents() {
    const input = this.element.querySelector('.tag-input');
    const dropdown = this.element.querySelector('.tag-dropdown');

    // Autocomplete on input
    let timeout;
    input.addEventListener('input', (e) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => this.search(e.target.value), 300);
    });

    // Add tag on Enter or click
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        this.addTag(input.value.trim());
        input.value = '';
        dropdown.style.display = 'none';
      }
    });

    // Remove tag clicks
    this.element.addEventListener('click', (e) => {
      if (e.target.classList.contains('tag-remove')) {
        this.removeTag(e.target.dataset.tag);
      }
    });

    // Dropdown clicks
    dropdown.addEventListener('click', (e) => {
      if (e.target.classList.contains('tag-suggestion')) {
        this.addTag(e.target.dataset.tag);
        input.value = '';
        dropdown.style.display = 'none';
      }
    });

    // Close dropdown on blur
    input.addEventListener('blur', () => {
      setTimeout(() => dropdown.style.display = 'none', 200);
    });
  }

  async search(query) {
    const dropdown = this.element.querySelector('.tag-dropdown');

    if (!query) {
      dropdown.style.display = 'none';
      return;
    }

    try {
      const res = await fetch(`/admin/tags/search?q=${encodeURIComponent(query)}`);
      const tags = await res.json();

      if (tags.length === 0) {
        dropdown.innerHTML = `<div class="tag-suggestion-new">Press Enter to create "${query}"</div>`;
      } else {
        dropdown.innerHTML = tags
          .filter(t => !this.selectedTags.includes(t))
          .map(t => `<div class="tag-suggestion" data-tag="${t}">${t}</div>`)
          .join('');
      }

      dropdown.style.display = 'block';
    } catch (err) {
      console.error('Tag search failed:', err);
    }
  }

  addTag(tag) {
    if (!tag || this.selectedTags.includes(tag)) return;

    this.selectedTags.push(tag);
    this.updateDisplay();
  }

  removeTag(tag) {
    this.selectedTags = this.selectedTags.filter(t => t !== tag);
    this.updateDisplay();
  }

  updateDisplay() {
    // Update tag chips
    const chipsContainer = this.element.querySelector('.tag-chips');
    chipsContainer.innerHTML = this.selectedTags.map(tag => `
      <span class="tag-chip" data-tag="${this.escapeHtml(tag)}">
        ${this.escapeHtml(tag)}
        <button type="button" class="tag-remove" data-tag="${this.escapeHtml(tag)}">&times;</button>
      </span>
    `).join('');

    // Update hidden input
    this.element.querySelector('input[name="tag_slugs"]').value = this.selectedTags.join(',');
  }
}

// Auto-initialize
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.tag-picker').forEach(el => new TagPicker(el));
});

